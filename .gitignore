# --- OpenProteo .gitignore ---
# Goal: the git-tracked tree matches the delivered source zip exactly, so that
# GitHub "Code > Download ZIP" yields the same sources. Only build/IDE/runtime
# artifacts (never part of the sources) are excluded.

# Maven build output
target/
*.war
*.class

# IDE / editor
.idea/
*.iml
.vscode/
.settings/
.project
.classpath

# OS noise
Thumbs.db
.DS_Store

# Runtime logs written by the app outside the sources
*.log
logs/
feeds/
